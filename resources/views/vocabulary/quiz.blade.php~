    <script>
        const questions = @json($questions);
        const totalQuestions = questions.length;
        const timePerQuestion = 30;

        let currentIndex = 0;
        let timeLeft = timePerQuestion;
        let timerInterval = null;
        let locked = false;

        const timerEl = document.getElementById('timer');
        const progressText = document.getElementById('question-progress');
        const labelEl = document.getElementById('question-label');
        const promptEl = document.getElementById('question-prompt');
        const optionsContainer = document.getElementById('options-container');
        const form = document.getElementById('quiz-form');
        const skipBtn = document.getElementById('skip-btn');
        const progressBar = document.getElementById('progress-bar');

        function updateProgress() {
            const percent = ((currentIndex + 1) / totalQuestions) * 100;
            progressBar.style.width = percent + "%";
            progressText.textContent = `${currentIndex + 1} / ${totalQuestions}`;
        }

        function updateTimerUI() {
            timerEl.textContent = timeLeft;

            const timerWrapper = timerEl.parentElement;
            timerWrapper.classList.remove('bg-red-100', 'text-red-700', 'bg-yellow-100', 'text-yellow-700', 'animate-pulse');

            if (timeLeft <= 5) {
                timerWrapper.classList.add('bg-red-100', 'text-red-700', 'animate-pulse');
            } else if (timeLeft <= 10) {
                timerWrapper.classList.add('bg-yellow-100', 'text-yellow-700');
            } else {
                timerWrapper.classList.add('bg-red-100', 'text-red-700');
            }
        }

        function restartTimer() {
            clearInterval(timerInterval);

            timerInterval = setInterval(() => {
                timeLeft--;
                updateTimerUI();

                if (timeLeft <= 0) {
                    clearInterval(timerInterval);
                    goToNextQuestion();
                }
            }, 1000);
        }

        function renderQuestion() {
            if (currentIndex >= totalQuestions) {
                form.submit();
                return;
            }

            locked = false;
            timeLeft = timePerQuestion;

            const question = questions[currentIndex];

            updateTimerUI();
            updateProgress();

            labelEl.textContent = `Question ${currentIndex + 1}`;
            promptEl.textContent = question.prompt;

            optionsContainer.innerHTML = '';

            question.options.forEach((option) => {
                const button = document.createElement('button');
                button.type = 'button';
                button.className = 'w-full text-left p-4 rounded-2xl border bg-white transition hover:border-amber-400 hover:bg-amber-50';
                button.textContent = option;

                button.addEventListener('click', () => {
                    if (locked) return;
                    locked = true;

                    const hiddenInput = document.getElementById(`answer-input-${question.vocabulary_id}`);
                    hiddenInput.value = option;

                    button.classList.add('border-amber-600', 'bg-amber-100', 'ring-2', 'ring-amber-200');

                    setTimeout(() => {
                        goToNextQuestion();
                    }, 500);
                });

                optionsContainer.appendChild(button);
            });

            restartTimer();
        }

        function goToNextQuestion() {
            clearInterval(timerInterval);
            currentIndex++;
            renderQuestion();
        }

        skipBtn.addEventListener('click', () => {
            goToNextQuestion();
        });

        renderQuestion();
    </script>
